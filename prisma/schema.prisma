generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  INSPECTOR
  ADMIN
}

enum Badge {
  STARTER
  PRO
  EXPERT
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum OrderStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  QUALITY_CHECK
  DELIVERED
  CANCELLED
}

enum Formula {
  ESSENTIEL
  STANDARD
  PREMIUM
}

enum PaymentMethod {
  CARD
  WAFACASH
  WIRE
  WESTERN_UNION
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  APPROVED
  DELIVERED
}

enum SubscriptionPlan {
  STARTER
  PRO
  EXPERT
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?
  password      String?
  image         String?
  role          Role      @default(CLIENT)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions     Session[]
  orders       Order[]   @relation("OrderClient")
  notifications Notification[]
  reviews      Review[]  @relation("ReviewClient")

  inspectorProfile   InspectorProfile? @relation("InspectorUser")
  referralCode      String?   @unique
  referredBy        User?     @relation("Referrals", fields: [referredById], references: [id])
  referredById       String?
  referrals         User[]    @relation("Referrals")
  referralCredits   Float     @default(0)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model InspectorProfile {
  id                 String            @id @default(cuid())
  userId             String            @unique
  user               User              @relation("InspectorUser", fields: [userId], references: [id], onDelete: Cascade)
  cities             String[]
  bio                String?           @db.Text
  certificationUrl   String?
  idPhotoUrl         String?
  badge              Badge             @default(STARTER)
  subscriptionStatus SubscriptionStatus @default(PENDING)
  subscriptionEnd    DateTime?
  rating             Float             @default(0)
  totalMissions      Int               @default(0)
  approved           Boolean           @default(false)
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  orders        Order[]   @relation("OrderInspector")
  reports       Report[]
  subscriptions Subscription[]
  reviews       Review[]   @relation("InspectorReview")
}

model Order {
  id                        String        @id @default(cuid())
  clientId                  String
  client                    User          @relation("OrderClient", fields: [clientId], references: [id])
  inspectorId               String?
  inspector                 InspectorProfile? @relation("OrderInspector", fields: [inspectorId], references: [id])
  status                    OrderStatus   @default(PENDING)
  formula                   Formula
  propertyAddress           String
  propertyCity             String
  propertyType             String
  surfaceArea              Int?
  propertyPhotos           String[]      @default([])
  notes                    String?       @db.Text
  clientPrice              Int
  inspectorShare           Int
  margin                   Int
  paymentMethod            PaymentMethod
  paymentStatus            PaymentStatus @default(PENDING)
  paymentProofUrl          String?
  cashAmountConfirmedClient Boolean       @default(false)
  cashAmountConfirmedInspector Boolean   @default(false)
  clientCashAmount         Int?
  inspectorCashAmount      Int?
  scheduledDate            DateTime?
  createdAt               DateTime       @default(now())
  deliveredAt              DateTime?

  report  Report?
  review  Review?
}

model Report {
  id            String       @id @default(cuid())
  orderId       String       @unique
  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  inspectorId   String
  inspector     InspectorProfile @relation(fields: [inspectorId], references: [id])
  status        ReportStatus @default(DRAFT)
  checklistData Json?
  photos        String[]     @default([])
  videoUrl      String?
  pdfUrl        String?
  inspectorNotes String?    @db.Text
  adminNotes    String?      @db.Text
  estimatedRepairCostMin Int?
  estimatedRepairCostMax Int?
  estimatedMarketValue Int?
  recommendation String?
  submittedAt   DateTime?
  approvedAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Subscription {
  id          String            @id @default(cuid())
  inspectorId String
  inspector   InspectorProfile  @relation(fields: [inspectorId], references: [id], onDelete: Cascade)
  plan        SubscriptionPlan
  price       Int
  startDate   DateTime
  endDate     DateTime
  status      SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String   @db.Text
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())
}

model Review {
  id           String   @id @default(cuid())
  orderId      String   @unique
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  clientId     String
  client       User     @relation("ReviewClient", fields: [clientId], references: [id])
  inspectorId  String
  inspector    InspectorProfile @relation("InspectorReview", fields: [inspectorId], references: [id])
  rating       Int
  comment      String?  @db.Text
  createdAt    DateTime @default(now())
}

model PaymentRecord {
  id            String   @id @default(cuid())
  orderId       String?
  subscriptionId String?
  amount        Int
  currency      String   @default("MAD")
  method        PaymentMethod
  status        PaymentStatus
  stripePaymentIntentId String?
  proofUrl      String?
  notes         String?
  confirmedAt   DateTime?
  createdAt     DateTime @default(now())
}

model InspectorPayout {
  id            String   @id @default(cuid())
  inspectorId   String
  orderId       String
  amount        Int
  status        String   @default("PENDING")
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime @default(now())
}

model ReferralVisit {
  id            String   @id @default(cuid())
  referralCode  String
  visitorIp     String?
  userAgent     String?
  converted     Boolean  @default(false)
  orderId       String?
  createdAt     DateTime @default(now())
}
